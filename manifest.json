{
  "manifest_version": 3,
  "name": "Deadline Tracker",
  "version": "2.7.0",
  "description": "Compact deadline tracker with working reminders, edit, delete, done state, optional time, and minute countdowns.",
  "permissions": [
    "storage",
    "notifications",
    "alarms"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Deadlines",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}